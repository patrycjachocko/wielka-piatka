{
  "ConnectionStrings": {
    "TimetableDb": "Data Source=timetable-service.db"
  },
  "TimetableApi": {
    "Url": "https://degra.wi.pb.edu.pl/rozklady/webservices.php"
  },
  "Sync": {
    "RunOnStartup": true,
    "InitialDelaySeconds": 5,
    "IntervalMinutes": 60
  },
  "RabbitMq": {
    "ManagementBaseUrl": "http://localhost:15672",
    "UserName": "guest",
    "Password": "guest",
    "VHost": "/",
    "Exchange": "timetable.events"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
